generator client {
  provider      = "prisma-client-js"
  runtime       = "nodejs"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH MODELS ─────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  name           String
  hashedPassword String
  role           UserRole @default(STAFF)
  isActive       Boolean  @default(true)
  staffId        Int?     @unique
  staff          Staff?   @relation(fields: [staffId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CONTACT (Unified Customer / Client Identity) ─────

model Contact {
  id                   Int      @id @default(autoincrement())
  name                 String
  phone                String   @unique
  email                String?
  address              String?
  gstNumber            String? // kept for B2B reference
  state                String?
  source               String?
  notes                String?
  emailSubscribed      Boolean  @default(true)
  // NRI buyer fields
  nriCountry           String?
  nriCurrency          String?  @default("USD")
  preferredContactTime String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  leads         Lead[]
  appointments  Appointment[]
  walkins       Walkin[]
  callLogs      CallLog[]
  conversations Conversation[]
  reviews       Review[]
  dailyPayments DailyPayment[]

  // Real Estate CRM back-relations (additive)
  costSheets          CostSheet[]
  bookings            Booking[]
  deals               Deal[]
  kycRecords          KYCRecord[]
  buyerSessions       BuyerSession[]
  supportTickets      SupportTicket[]
  referralsAsReferrer Referral[]     @relation("ReferrerContact")
  referralsAsReferred Referral[]     @relation("ReferredContact")
  tasks               Task[]
  loanApplications    LoanApplication[]
  signatures          DocumentSignature[]
  waitlists           UnitWaitlist[]
  snagReports         SnagReport[]

  @@index([email])
  @@index([emailSubscribed])
}

// ─── LEAD MANAGEMENT ─────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  SHOWROOM_VISIT
  QUOTATION
  WON
  LOST
}

model Lead {
  id           Int        @id @default(autoincrement())
  contactId    Int
  contact      Contact    @relation(fields: [contactId], references: [id])
  interest     String
  budget       String?
  status       LeadStatus @default(NEW)
  source       String?
  date         DateTime   @default(now())
  notes        String?
  assignedToId Int?
  assignedTo   Staff?     @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  followUps     FollowUp[]
  indiaMartLead IndiaMartLead?

  // Real Estate CRM back-relations (additive)
  cpLead     CPLead?
  portalLead PortalLead?

  @@index([status])
  @@index([date])
  @@index([assignedToId])
}

model FollowUp {
  id      Int      @id @default(autoincrement())
  leadId  Int
  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  day     Int
  message String
  sent    Boolean  @default(false)
  date    DateTime

  @@index([leadId])
}

// ─── APPOINTMENTS ────────────────────────────────────

model Appointment {
  id        Int      @id @default(autoincrement())
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id])
  date      DateTime
  time      String
  purpose   String
  status    String   @default("Scheduled")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

// ─── WALK-INS ────────────────────────────────────────

enum WalkinStatus {
  BROWSING
  INTERESTED
  FOLLOW_UP
  CONVERTED
  LEFT
}

model Walkin {
  id            Int          @id @default(autoincrement())
  contactId     Int
  contact       Contact      @relation(fields: [contactId], references: [id])
  requirement   String
  assignedToId  Int?
  assignedTo    Staff?       @relation("WalkinAssigned", fields: [assignedToId], references: [id])
  date          DateTime
  time          String
  status        WalkinStatus @default(BROWSING)
  budget        String?
  notes         String?
  source        String       @default("Walk-in")
  visitDuration String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([date])
  @@index([status])
}

// ─── STAFF ───────────────────────────────────────────

model Staff {
  id         Int      @id @default(autoincrement())
  name       String
  role       String
  phone      String
  email      String   @unique
  status     String   @default("Active")
  joinDate   DateTime
  avatar     String?
  stats      Json?
  target     Json?
  commission Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Payroll fields
  basicSalary          Int     @default(0)
  designation          String?
  panNumber            String?
  bankAccount          String?
  bankName             String?
  ifscCode             String?
  pfEnrolled           Boolean @default(false)
  esiEnrolled          Boolean @default(false)
  uanNumber            String? // Universal Account Number (PF)
  pfNumber             String? // PF registration number
  esiNumber            String? // ESI registration number
  professionalTaxState String  @default("Maharashtra")
  tdsMonthly           Int     @default(0) // fixed monthly TDS amount

  user             User?
  leads            Lead[]
  walkins          Walkin[]          @relation("WalkinAssigned")
  attendance       Attendance[]
  activities       StaffActivity[]
  fieldVisits      FieldVisit[]
  payslips         Payslip[]
  loans            StaffLoan[]
  expenses         Expense[]         @relation("StaffExpenses")
  receivedPayments DailyPayment[]

  // Real Estate CRM back-relations (additive)
  agentScores AgentScore[]
  agentBadges AgentBadge[]
  deals       Deal[]
  tasks       Task[]
  loanApplications LoanApplication[]
  agentTargets AgentTarget[]
  snagReports SnagReport[]
  agentLocations AgentLocation[]

  @@index([email])
}

model Attendance {
  id           Int      @id @default(autoincrement())
  staffId      Int
  staff        Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date         DateTime
  clockIn      String?
  clockOut     String?
  hours        Float?
  status       String
  // GPS tracking
  clockInLat   Float?
  clockInLng   Float?
  clockOutLat  Float?
  clockOutLng  Float?
  clockInDist  Float? // distance from office in meters
  clockOutDist Float?
  method       String   @default("manual") // "gps", "manual"
  isLate       Boolean  @default(false)

  @@unique([staffId, date])
  @@index([date])
  @@index([staffId])
  @@index([staffId, date])
}

model StaffActivity {
  id      Int      @id @default(autoincrement())
  staffId Int
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type    String
  text    String
  time    String
  date    DateTime

  @@index([staffId])
  @@index([date])
}

// ─── FIELD VISITS ─────────────────────────────────────
// Repurposed for real-estate site visits / property inspections

model FieldVisit {
  id            Int      @id @default(autoincrement())
  displayId     String
  staffId       Int
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  // Plain Int reference (no FK) — will link to a future Property model
  customOrderId Int?     // legacy column kept as nullable plain Int — use for property/deal reference
  customer      String
  address       String
  date          DateTime
  time          String
  scheduledDate DateTime? // when the visit is scheduled for
  scheduledTime String?   // time slot e.g. "10:00 AM - 12:00 PM"
  status        String    // Scheduled, In Progress, Completed, Cancelled
  completedAt   DateTime?
  type          String
  notes         String?
  staffNotes    String?   // notes added by staff after visit
  measurements  Json?
  photos        Int       @default(0)
  photoUrls     String[]

  // Site Visit 2.0 extensions (Req 12.1) — additive
  projectId        Int?
  unitIds          Int[]
  geoCheckinLat    Float?
  geoCheckinLng    Float?
  geoCheckinTime   DateTime?
  otpCode          String?
  otpVerified      Boolean   @default(false)
  buyerRating      Int? // 1..5
  feedbackLiked    String?
  feedbackDisliked String?
  feedbackConcerns String?
  followUpAction   String?
  visitDurationMin Int?

  @@index([staffId])
  @@index([scheduledDate])
}

// ─── CALL LOGS ───────────────────────────────────────

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  COMPLETED
  MISSED
  NO_ANSWER
  BUSY
}

model CallLog {
  id           Int           @id @default(autoincrement())
  contactId    Int?
  contact      Contact?      @relation(fields: [contactId], references: [id])
  customerName String
  phone        String
  direction    CallDirection
  status       CallStatus
  duration     String?
  durationSec  Int           @default(0)
  agent        String        @default("AI Agent")
  date         DateTime
  time         String
  purpose      String?
  outcome      String?
  notes        String?
  recording    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  // AI calling agent fields
  livekitRoomId String?
  callType      String? @default("manual") // manual | ai_inbound | ai_outbound | browser_test
  aiHandled     Boolean @default(false)

  transcript CallTranscript?

  @@index([date])
  @@index([contactId])
}

model CallTranscript {
  id        Int     @id @default(autoincrement())
  callLogId Int     @unique
  callLog   CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  summary   String?
  sentiment String?
  messages  Json
}

// ─── CONVERSATIONS ───────────────────────────────────

enum ConversationStatus {
  AI_HANDLED
  NEEDS_HUMAN
  RESOLVED
}

model Conversation {
  id           Int                @id @default(autoincrement())
  contactId    Int?
  contact      Contact?           @relation(fields: [contactId], references: [id])
  customerName String
  channel      String
  externalId   String? // platform-specific thread/chat ID (e.g. WhatsApp phone, IG thread)
  status       ConversationStatus @default(AI_HANDLED)
  lastMessage  String?
  unread       Int                @default(0)
  date         DateTime
  messages     Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channel])
  @@index([status])
  @@index([externalId])
}

// ─── REVIEWS ─────────────────────────────────────────

model Review {
  id           Int      @id @default(autoincrement())
  contactId    Int?
  contact      Contact? @relation(fields: [contactId], references: [id])
  customerName String
  rating       Int
  text         String
  date         DateTime
  product      String   // repurposed: property/service name
  platform     String   @default("Google")
  replied      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([rating])
  @@index([platform])
}

// ─── MARKETING CAMPAIGNS ─────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

model Campaign {
  id            Int            @id @default(autoincrement())
  name          String
  channel       String
  status        CampaignStatus @default(DRAFT)
  scheduledDate DateTime?
  audience      Int            @default(0)
  sent          Int            @default(0)
  opened        Int            @default(0)
  clicked       Int            @default(0)
  template      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── MARKETPLACE CHANNELS ────────────────────────────

model MarketplaceChannel {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String
  logo      String?
  color     String?
  connected Boolean   @default(false)
  lastSync  DateTime?
  sellerId  String?
  config    Json?
}

// ─── STORE / AGENCY SETTINGS ─────────────────────────

model StoreSettings {
  id              Int      @id @default(1)
  storeName       String   @default("Real Estate Agency")
  phone           String?
  whatsappNumber  String?
  email           String?
  address         String?
  paymentQr       String?
  invoicePrefix   String   @default("INV-")
  invoicePadding  Int      @default(4)
  invoiceTerms    String?
  bankName        String?
  bankAccountName String?
  bankAccountNumber String?
  bankIfsc        String?
  bankUpiId       String?
  gstNumber       String?
  gstRate         Float    @default(18.0)
  currency        String   @default("INR")
  logo            String?
  // Geofence for GPS attendance
  storeLat        Float?
  storeLng        Float?
  geofenceRadius  Int      @default(100) // meters
  shiftStartTime  String   @default("09:00") // HH:mm — late after this
  shiftEndTime    String   @default("20:00") // HH:mm — shift ends
  // SMTP Email Configuration
  smtpHost        String?
  smtpPort        Int?     @default(587)
  smtpUser        String?
  smtpPass        String?
  smtpFromName    String?
  smtpSecure      Boolean  @default(false)
  smtpConfigured  Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

// ─── IN-APP NOTIFICATIONS ───────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  subtitle  String
  href      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([read])
  @@index([type])
  @@index([read, createdAt])
}

// ─── STORE CAMPAIGNS (QR Codes) ──────────────────────

model StoreCampaign {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  location  String
  scans     Int      @default(0)
  leads     Int      @default(0)
  status    String   @default("Active")
  purpose   String?
  createdAt DateTime @default(now())
}

// ─── CHANNEL INTEGRATIONS ────────────────────────────

model ChannelConfig {
  id         Int      @id @default(autoincrement())
  channel    String   @unique // WhatsApp, Instagram, Facebook, Website
  enabled    Boolean  @default(false)
  config     Json // API keys, tokens, phone numbers, page IDs, etc.
  webhookUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- INDIA MART LEADS INTEGRATION ---

model IndiaMartConfig {
  id                Int        @id @default(1)
  enabled           Boolean    @default(false)
  pullApiKey        String?
  autoImportToLeads Boolean    @default(true)
  defaultLeadStatus LeadStatus @default(NEW)
  overlapMinutes    Int        @default(5)
  lastSyncAt        DateTime?
  lastSyncStart     DateTime?
  lastSyncEnd       DateTime?
  lastSyncCode      Int?
  lastSyncMessage   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model IndiaMartLead {
  id               Int       @id @default(autoincrement())
  uniqueQueryId    String    @unique
  queryType        String?
  queryTime        DateTime?
  senderName       String
  senderMobile     String?
  senderEmail      String?
  senderCompany    String?
  senderAddress    String?
  senderCity       String?
  senderState      String?
  senderPincode    String?
  senderCountryIso String?
  senderMobileAlt  String?
  senderEmailAlt   String?
  queryProductName String?
  queryMessage     String?
  queryMcatName    String?
  callDuration     String?
  receiverMobile   String?
  rawPayload       Json
  syncedAt         DateTime  @default(now())
  leadId           Int?      @unique
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([queryTime])
  @@index([queryType])
  @@index([syncedAt])
  @@index([leadId])
}

// ─── EMAIL MARKETING ────────────────────────────────

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  subject   String
  body      String   @db.Text
  category  String   @default("Promotional")
  variables String[]
  thumbnail String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns EmailCampaign[]
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
}

model EmailCampaign {
  id              Int                 @id @default(autoincrement())
  name            String
  subject         String
  body            String              @db.Text
  templateId      Int?
  template        EmailTemplate?      @relation(fields: [templateId], references: [id])
  status          EmailCampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  audience        String              @default("all")
  audienceFilter  Json?
  totalRecipients Int                 @default(0)
  sent            Int                 @default(0)
  opened          Int                 @default(0)
  clicked         Int                 @default(0)
  bounced         Int                 @default(0)
  unsubscribed    Int                 @default(0)
  // A/B testing
  isABTest        Boolean             @default(false)
  variantB        Json?
  abSplitPercent  Int                 @default(50)
  abWinner        String?
  // Automation
  isAutomated     Boolean             @default(false)
  triggerType     String?
  triggerDelay    Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  recipients EmailRecipient[]

  @@index([status])
  @@index([isAutomated, triggerType])
}

model EmailRecipient {
  id         Int           @id @default(autoincrement())
  campaignId Int
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  Int?
  email      String
  name       String
  variant    String        @default("A")
  status     String        @default("queued")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  opens      Int           @default(0)
  clicks     Int           @default(0)

  events EmailEvent[]

  @@index([campaignId])
  @@index([email])
  @@index([status])
}

model EmailEvent {
  id          Int            @id @default(autoincrement())
  recipientId Int
  recipient   EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type        String // open, click, bounce, unsubscribe
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([recipientId])
  @@index([type])
  @@index([createdAt])
}

// ─── DRAFTS (soft-delete, auto-purge after 30 days) ───

model Draft {
  id         Int      @id @default(autoincrement())
  sourceType String // "Lead", "Walkin", etc.
  sourceId   String
  data       Json
  deletedBy  String   @default("Manager")
  deletedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([sourceType])
  @@index([expiresAt])
}

// ─── STAFF PAYROLL ────────────────────────────────────

model PayrollRun {
  id                    Int       @id @default(autoincrement())
  displayId             String    @unique
  period                String
  status                String    @default("DRAFT")
  totalGross            Int       @default(0)
  totalDeductions       Int       @default(0)
  totalNet              Int       @default(0)
  employerContributions Int       @default(0)
  processedAt           DateTime  @default(now())
  paidAt                DateTime?
  processedBy           String?
  createdAt             DateTime  @default(now())

  payslips Payslip[]

  @@index([status])
}

model Payslip {
  id               Int        @id @default(autoincrement())
  payrollRunId     Int
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staffId          Int
  staff            Staff      @relation(fields: [staffId], references: [id])
  workingDays      Int        @default(26)
  presentDays      Float      @default(0)
  basicSalary      Int        @default(0)
  hra              Int        @default(0)
  da               Int        @default(0)
  specialAllowance Int        @default(0)
  otHours          Float      @default(0)
  otPay            Int        @default(0)
  bonus            Int        @default(0)
  grossSalary      Int        @default(0)
  pfEmployee       Int        @default(0)
  pfEmployer       Int        @default(0)
  esiEmployee      Int        @default(0)
  esiEmployer      Int        @default(0)
  professionalTax  Int        @default(0)
  tds              Int        @default(0)
  loanDeduction    Int        @default(0)
  otherDeductions  Int        @default(0)
  totalDeductions  Int        @default(0)
  netSalary        Int        @default(0)
  status           String     @default("Generated")
  createdAt        DateTime   @default(now())

  @@unique([payrollRunId, staffId])
  @@index([staffId])
}

model StaffLoan {
  id                 Int      @id @default(autoincrement())
  staffId            Int
  staff              Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  purpose            String
  principalAmount    Int
  remainingAmount    Int
  monthlyInstallment Int
  startPeriod        String // YYYY-MM
  status             String   @default("Active") // Active, Closed
  notes              String?
  createdAt          DateTime @default(now())

  @@index([staffId])
  @@index([status])
}

// ─── DAILY EXPENSE CALCULATOR ────────────────────────

model ExpenseCategory {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  icon              String?
  color             String?
  budget            Int                @default(0)
  isDefault         Boolean            @default(false)
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id          Int             @id @default(autoincrement())
  date        DateTime
  categoryId  Int
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Int
  description String
  paymentMode String          @default("Cash")
  reference   String?
  receipt     String?
  vendor      String?
  staffId     Int?
  staff       Staff?          @relation("StaffExpenses", fields: [staffId], references: [id])
  status      String          @default("Approved")
  approvedBy  String?
  isRecurring Boolean         @default(false)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([status])
  @@index([staffId])
}

model RecurringExpense {
  id          Int             @id @default(autoincrement())
  categoryId  Int
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  description String
  amount      Int
  paymentMode String          @default("Bank Transfer")
  vendor      String?
  frequency   String          @default("Monthly")
  dayOfMonth  Int?
  dayOfWeek   Int?
  isActive    Boolean         @default(true)
  startDate   DateTime        @default(now())
  endDate     DateTime?
  lastRun     DateTime?
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([isActive])
  @@index([frequency])
}

model DailyCashRegister {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  openingCash Int      @default(0)
  closingCash Int?
  cashIn      Int      @default(0)
  cashOut     Int      @default(0)
  notes       String?
  closedBy    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ─── DAILY PAYMENTS ─────────────────────────────────
// Repurposed for real estate: token amounts, booking payments, commission, etc.

model DailyPayment {
  id              Int      @id @default(autoincrement())
  displayId       String   @unique
  amount          Int
  gstAmount       Int      @default(0)
  type            String   @default("IN")      // IN = received, OUT = given
  method          String                       // Cash, UPI, Card, Bank Transfer, Cheque
  reference       String?
  referenceHash   String?
  date            DateTime @default(now())
  status          String   @default("Pending") // Pending, Reconciled, Reversed, Bounced

  // Staff tracking
  receivedByStaffId Int?
  receivedByStaff   Staff?  @relation(fields: [receivedByStaffId], references: [id])

  // Cheque-specific fields
  chequeNumber  String?
  chequeDate    DateTime?
  chequeBounced Boolean  @default(false)
  bounceReason  String?

  customerName  String?

  // Document linking — plain Int references (no FK) for future property/deal models
  contactId     Int?
  contact       Contact? @relation(fields: [contactId], references: [id])
  orderId       Int?     // plain nullable Int — no FK (Order model removed)
  invoiceId     Int?     // plain nullable Int — no FK (Invoice model removed)
  customOrderId Int?     // plain nullable Int — no FK (CustomOrder model removed)

  // Reconciliation
  reconciled      Boolean  @default(false)
  reconciledDate  DateTime?
  reconciledBy    String?
  bankRefNumber   String?

  // Reversal tracking
  reversalId      Int?
  isReversal      Boolean  @default(false)
  reversalReason  String?

  notes      String?
  attachment String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@index([method])
  @@index([contactId])
  @@index([type])
  @@index([status])
  @@index([reconciled])
  @@index([chequeBounced])
  @@index([referenceHash])
}

// ─── FINANCIAL STATEMENTS ────────────────────────────

model AccountGroup {
  id       Int            @id @default(autoincrement())
  name     String         @unique
  type     String // ASSET | LIABILITY | INCOME | EXPENSE | EQUITY
  parentId Int?
  parent   AccountGroup?  @relation("AccountGroupHierarchy", fields: [parentId], references: [id])
  children AccountGroup[] @relation("AccountGroupHierarchy")

  accounts LedgerAccount[]
}

model LedgerAccount {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  name            String
  groupId         Int
  group           AccountGroup @relation(fields: [groupId], references: [id])
  openingBalance  Int          @default(0)
  isSystemAccount Boolean      @default(false)
  createdAt       DateTime     @default(now())

  lines JournalLine[]

  @@index([groupId])
}

model JournalEntry {
  id            Int      @id @default(autoincrement())
  displayId     String   @unique
  date          DateTime
  narration     String
  referenceType String?
  referenceId   Int?
  totalDebit    Int
  totalCredit   Int
  status        String   @default("POSTED")
  createdBy     String?
  createdAt     DateTime @default(now())

  lines JournalLine[]

  @@index([date])
  @@index([status])
}

model JournalLine {
  id             Int           @id @default(autoincrement())
  journalEntryId Int
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      Int
  account        LedgerAccount @relation(fields: [accountId], references: [id])
  debit          Int           @default(0)
  credit         Int           @default(0)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
}

// ============================================================
// WhatsApp CRM (Prisma-backed replacement for Supabase tables)
// ============================================================

model WaProfile {
  id         String   @id @default(cuid())
  user_id    String   @unique
  full_name  String
  email      String
  avatar_url String?
  role       String?  @default("user")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  assigned_deals WaDeal[] @relation("WaDealAssignee")

  @@map("profiles")
}

model WaContact {
  id         String   @id @default(cuid())
  user_id    String
  phone      String
  name       String?
  email      String?
  company    String?
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  conversations                 WaConversation[]
  contact_tags                  WaContactTag[]
  contact_custom_values         WaContactCustomValue[]
  contact_notes                 WaContactNote[]
  deals                         WaDeal[]
  broadcast_recipients          WaBroadcastRecipient[]
  automation_logs               WaAutomationLog[]
  automation_pending_executions WaAutomationPendingExecution[]

  @@index([user_id])
  @@index([phone])
  @@map("contacts")
}

model WaTag {
  id         String   @id @default(cuid())
  user_id    String
  name       String
  color      String   @default("#3b82f6")
  created_at DateTime @default(now())

  contact_tags WaContactTag[]

  @@index([user_id])
  @@map("tags")
}

model WaContactTag {
  id         String   @id @default(cuid())
  contact_id String
  tag_id     String
  created_at DateTime @default(now())

  contact WaContact @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  tag     WaTag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([contact_id, tag_id])
  @@index([contact_id])
  @@index([tag_id])
  @@map("contact_tags")
}

model WaCustomField {
  id            String   @id @default(cuid())
  user_id       String
  field_name    String
  field_type    String   @default("text")
  field_options Json?
  created_at    DateTime @default(now())

  contact_custom_values WaContactCustomValue[]

  @@index([user_id])
  @@map("custom_fields")
}

model WaContactCustomValue {
  id              String   @id @default(cuid())
  contact_id      String
  custom_field_id String
  value           String?
  created_at      DateTime @default(now())

  contact      WaContact     @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  custom_field WaCustomField @relation(fields: [custom_field_id], references: [id], onDelete: Cascade)

  @@unique([contact_id, custom_field_id])
  @@index([contact_id])
  @@index([custom_field_id])
  @@map("contact_custom_values")
}

model WaContactNote {
  id         String   @id @default(cuid())
  contact_id String
  user_id    String
  note_text  String
  created_at DateTime @default(now())

  contact WaContact @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@index([contact_id])
  @@index([user_id])
  @@map("contact_notes")
}

model WaConversation {
  id                String   @id @default(cuid())
  user_id           String
  contact_id        String
  status            String   @default("open")
  needs_human       Boolean  @default(false)
  assigned_agent_id String?
  last_message_text String?
  last_message_at   DateTime?
  unread_count      Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  contact           WaContact          @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  messages          WaMessage[]
  deals             WaDeal[]
  message_reactions WaMessageReaction[]

  @@unique([user_id, contact_id])
  @@index([user_id])
  @@index([contact_id])
  @@index([last_message_at])
  @@map("conversations")
}

model WaMessage {
  id                  String   @id @default(cuid())
  conversation_id     String
  sender_type         String
  sender_id           String?
  content_type        String   @default("text")
  content_text        String?
  media_url           String?
  template_name       String?
  message_id          String?
  status              String   @default("sent")
  created_at          DateTime @default(now())
  reply_to_message_id String?

  conversation     WaConversation    @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  reply_to_message WaMessage?        @relation("WaMessageReplies", fields: [reply_to_message_id], references: [id], onDelete: SetNull)
  replies          WaMessage[]       @relation("WaMessageReplies")
  reactions        WaMessageReaction[]

  @@index([conversation_id])
  @@index([message_id])
  @@index([reply_to_message_id])
  @@map("messages")
}

model WaWhatsappConfig {
  id              String   @id @default(cuid())
  user_id         String   @unique
  phone_number_id String
  waba_id         String?
  access_token    String
  // Meta App Secret (encrypted). Used to HMAC-verify inbound webhook
  // POSTs. Configurable from the WhatsApp Marketing settings UI so the
  // operator no longer has to set a META_APP_SECRET env var + redeploy.
  app_secret      String?
  verify_token    String?
  status          String   @default("disconnected")
  connected_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([phone_number_id])
  @@map("whatsapp_config")
}

model WaMessageTemplate {
  id             String   @id @default(cuid())
  user_id        String
  name           String
  category       String   @default("Marketing")
  language       String   @default("en_US")
  header_type    String?
  header_content String?
  body_text      String
  footer_text    String?
  buttons        Json?
  status         String   @default("Draft")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([user_id])
  @@index([name, language])
  @@map("message_templates")
}

model WaPipeline {
  id         String   @id @default(cuid())
  user_id    String
  name       String
  created_at DateTime @default(now())

  stages WaPipelineStage[]
  deals  WaDeal[]

  @@index([user_id])
  @@map("pipelines")
}

model WaPipelineStage {
  id          String   @id @default(cuid())
  pipeline_id String
  name        String
  position    Int      @default(0)
  color       String   @default("#3b82f6")
  created_at  DateTime @default(now())

  pipeline WaPipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  deals    WaDeal[]

  @@index([pipeline_id])
  @@index([position])
  @@map("pipeline_stages")
}

model WaDeal {
  id                  String   @id @default(cuid())
  user_id             String
  pipeline_id         String
  stage_id            String
  contact_id          String?
  conversation_id     String?
  assigned_to         String?
  title               String
  value               Float    @default(0)
  currency            String?  @default("INR")
  notes               String?
  expected_close_date DateTime?
  status              String   @default("open")
  crm_deal_id         Int?     // FK-free plain Int reference to CRM Deal
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  pipeline     WaPipeline      @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  stage        WaPipelineStage @relation(fields: [stage_id], references: [id])
  contact      WaContact?      @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  conversation WaConversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  assignee     WaProfile?      @relation("WaDealAssignee", fields: [assigned_to], references: [id], onDelete: SetNull)

  @@index([pipeline_id])
  @@index([stage_id])
  @@index([contact_id])
  @@index([user_id, status])
  @@map("deals")
}

model WaBroadcast {
  id                String   @id @default(cuid())
  user_id           String
  name              String
  template_name     String
  template_language String   @default("en_US")
  template_variables Json?
  audience_filter   Json?
  scheduled_at      DateTime?
  status            String   @default("draft")
  total_recipients  Int      @default(0)
  sent_count        Int      @default(0)
  delivered_count   Int      @default(0)
  read_count        Int      @default(0)
  replied_count     Int      @default(0)
  failed_count      Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  recipients WaBroadcastRecipient[]

  @@index([user_id])
  @@index([created_at])
  @@map("broadcasts")
}

model WaBroadcastRecipient {
  id                  String   @id @default(cuid())
  broadcast_id        String
  contact_id          String?
  status              String   @default("pending")
  sent_at             DateTime?
  delivered_at        DateTime?
  read_at             DateTime?
  replied_at          DateTime?
  error_message       String?
  whatsapp_message_id String?  @unique
  created_at          DateTime @default(now())

  broadcast WaBroadcast @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  contact   WaContact?  @relation(fields: [contact_id], references: [id], onDelete: SetNull)

  @@index([broadcast_id])
  @@index([broadcast_id, status])
  @@index([contact_id])
  @@map("broadcast_recipients")
}

model WaAutomation {
  id               String   @id @default(cuid())
  user_id          String
  name             String
  description      String?
  trigger_type     String
  trigger_config   Json     @default("{}")
  is_active        Boolean  @default(false)
  execution_count  Int      @default(0)
  last_executed_at DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  steps              WaAutomationStep[]
  logs               WaAutomationLog[]
  pending_executions WaAutomationPendingExecution[]

  @@index([user_id])
  @@index([trigger_type, is_active])
  @@map("automations")
}

model WaAutomationStep {
  id             String   @id @default(cuid())
  automation_id  String
  parent_step_id String?
  branch         String?
  step_type      String
  step_config    Json     @default("{}")
  position       Int
  created_at     DateTime @default(now())

  automation   WaAutomation       @relation(fields: [automation_id], references: [id], onDelete: Cascade)
  parent_step  WaAutomationStep?  @relation("WaAutomationStepHierarchy", fields: [parent_step_id], references: [id], onDelete: Cascade)
  child_steps  WaAutomationStep[] @relation("WaAutomationStepHierarchy")
  pending_children WaAutomationPendingExecution[] @relation("WaPendingParentStep")

  @@index([automation_id, position])
  @@index([parent_step_id])
  @@map("automation_steps")
}

model WaAutomationLog {
  id             String   @id @default(cuid())
  automation_id  String
  user_id        String
  contact_id     String?
  trigger_event  String
  steps_executed Json     @default("[]")
  status         String
  error_message  String?
  created_at     DateTime @default(now())

  automation WaAutomation @relation(fields: [automation_id], references: [id], onDelete: Cascade)
  contact    WaContact?   @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  pending    WaAutomationPendingExecution[]

  @@index([automation_id, created_at])
  @@index([user_id])
  @@index([contact_id])
  @@map("automation_logs")
}

model WaAutomationPendingExecution {
  id                 String   @id @default(cuid())
  automation_id      String
  user_id            String
  contact_id         String?
  log_id             String?
  parent_step_id     String?
  branch             String?
  next_step_position Int
  context            Json     @default("{}")
  status             String   @default("pending")
  run_at             DateTime
  created_at         DateTime @default(now())

  automation  WaAutomation      @relation(fields: [automation_id], references: [id], onDelete: Cascade)
  contact     WaContact?        @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  log         WaAutomationLog?  @relation(fields: [log_id], references: [id], onDelete: Cascade)
  parent_step WaAutomationStep? @relation("WaPendingParentStep", fields: [parent_step_id], references: [id], onDelete: SetNull)

  @@index([run_at, status])
  @@index([user_id])
  @@index([contact_id])
  @@map("automation_pending_executions")
}

model WaMessageReaction {
  id              String   @id @default(cuid())
  message_id      String
  conversation_id String
  actor_type      String
  actor_id        String?
  emoji           String
  created_at      DateTime @default(now())

  message      WaMessage      @relation(fields: [message_id], references: [id], onDelete: Cascade)
  conversation WaConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@unique([message_id, actor_type, actor_id])
  @@index([conversation_id])
  @@index([message_id])
  @@map("message_reactions")
}

