# ──────────────────────────────────────────────────────────────────────────────
#  RealZentic CRM — VPS Production Environment
#  Domain: realzentic.autozentic.com
#
#  INSTRUCTIONS:
#  1. Copy this file to .env on the VPS:  cp .env.production.example .env
#  2. Fill in every value marked CHANGE_ME
#  3. Never commit .env to git (it's already in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL — inside Docker, stored on VPS volume) ──────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=realestatecrm

# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=realzentic.autozentic.com

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://realzentic.autozentic.com
NEXT_PUBLIC_APP_URL=https://realzentic.autozentic.com
NEXT_PUBLIC_WS_URL=https://realzentic.autozentic.com:3001

# ─── Secrets (generate with: openssl rand -base64 32) ────────────────────────
NEXTAUTH_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
CRM_API_SECRET=CHANGE_ME

# ─── Encryption key (generate with: openssl rand -hex 32) ────────────────────
ENCRYPTION_KEY=CHANGE_ME

# ─── Redis (inside Docker) ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── File uploads (VPS volume — no cloud storage) ────────────────────────────
UPLOAD_DIR=/app/uploads

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── LLM Provider ─────────────────────────────────────────────────────────────
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_PROVIDER=groq

# ─── AI Agent ─────────────────────────────────────────────────────────────────
AI_AGENT_NAME=anushka

# ─── Sarvam TTS ───────────────────────────────────────────────────────────────
SARVAM_API_KEY=CHANGE_ME
TTS_PROVIDER=sarvam
SARVAM_TTS_LANGUAGE=hi-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=pooja
SARVAM_TTS_TRANSPORT=streaming
SARVAM_TTS_PACE=1.03
SARVAM_TTS_TEMPERATURE=0.55
SARVAM_TTS_MIN_BUFFER_SIZE=40
SARVAM_TTS_MAX_CHUNK_LENGTH=120

# ─── Deepgram STT ─────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=CHANGE_ME

# ─── LiveKit (AI calling — leave blank if not using) ─────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OUTBOUND_SIP_TRUNK_ID=
INBOUND_SIP_TRUNK_ID=

# ─── SIP / Telephony ──────────────────────────────────────────────────────────
VOBIZ_SIP_TRUNK_ID=
VOBIZ_SIP_DOMAIN=
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
